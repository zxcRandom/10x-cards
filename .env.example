SUPABASE_URL=###
SUPABASE_KEY=###
PUBLIC_SUPABASE_URL=###
PUBLIC_SUPABASE_ANON_KEY=###

# Site URL (used for sitemap and canonical URLs)
SITE_URL=https://10x-cards.pages.dev

# OpenRouter configuration (server-only)
OPENROUTER_API_KEY=###
