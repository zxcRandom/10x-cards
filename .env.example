AI_RATE_LIMIT_PER_MINUTE=10
AI_RATE_LIMIT_PER_DAY=250
AI_MAX_INPUT_LENGTH=20000
AI_DEFAULT_MAX_CARDS=20
AI_MAX_CARDS_LIMIT=50