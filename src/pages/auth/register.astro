---
/**
 * Register Page
 *
 * User registration page for creating new accounts.
 * Redirects to /decks if user is already authenticated.
 */

import Layout from "@/layouts/Layout.astro";
import RegisterForm from "@/components/auth/RegisterForm";

// Check if user is already logged in
const {
  data: { user },
} = await Astro.locals.supabase.auth.getUser();

if (user) {
  // Already logged in - redirect to decks
  return Astro.redirect("/decks");
}
---

<Layout title="Utwórz konto - 10x Cards">
  <div
    class="min-h-screen bg-gradient-to-br from-background via-background to-muted/20 flex items-center justify-center px-4 py-12"
  >
    <div class="w-full max-w-md space-y-8">
      <!-- Header -->
      <div class="text-center space-y-2">
        <a href="/" class="inline-block group">
          <h1 class="text-3xl font-bold tracking-tight group-hover:text-primary transition-colors">
            <span class="bg-gradient-to-r from-primary to-primary/60 bg-clip-text text-transparent"> 10x Cards </span>
          </h1>
        </a>
        <h2 class="text-2xl font-semibold">Utwórz konto</h2>
        <p class="text-muted-foreground">Dołącz do tysięcy użytkowników uczących się efektywniej</p>
      </div>

      <!-- Register Form Card -->
      <div class="rounded-lg border border-border bg-card shadow-lg p-8">
        <RegisterForm client:load />
      </div>

      <!-- Privacy Notice -->
      <p class="text-center text-xs text-muted-foreground">
        Rejestrując się, akceptujesz naszą{" "}
        <a
          href="/privacy-policy"
          class="text-primary hover:underline focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 rounded"
        >
          Politykę prywatności
        </a>
      </p>
    </div>
  </div>
</Layout>
