---
/**
 * Forgot Password Page
 * 
 * Password reset request page.
 */

import Layout from '@/layouts/Layout.astro';
import ForgotPasswordForm from '@/components/auth/ForgotPasswordForm';
---

<Layout title="Zresetuj hasło - 10x Cards">
  <div class="min-h-screen bg-gradient-to-br from-background via-background to-muted/20 flex items-center justify-center px-4 py-12">
    <div class="w-full max-w-md space-y-8">
      <!-- Header -->
      <div class="text-center space-y-2">
        <a href="/" class="inline-block group">
          <h1 class="text-3xl font-bold tracking-tight group-hover:text-primary transition-colors">
            <span class="bg-gradient-to-r from-primary to-primary/60 bg-clip-text text-transparent">
              10x Cards
            </span>
          </h1>
        </a>
        <h2 class="text-2xl font-semibold">Zresetuj hasło</h2>
        <p class="text-muted-foreground">
          Wyślemy Ci instrukcje resetowania hasła
        </p>
      </div>

      <!-- Forgot Password Form Card -->
      <div class="rounded-lg border border-border bg-card shadow-lg p-8">
        <ForgotPasswordForm client:load />
      </div>
    </div>
  </div>
</Layout>
