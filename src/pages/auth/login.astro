---
/**
 * Login Page
 * 
 * User authentication page with email/password login.
 * Redirects to /decks if user is already authenticated.
 */

import Layout from '@/layouts/Layout.astro';
import LoginForm from '@/components/auth/LoginForm';

// Check if user is already logged in
const { data: { user } } = await Astro.locals.supabase.auth.getUser();

if (user) {
  // Already logged in - redirect to decks
  return Astro.redirect('/decks');
}

// Get the 'next' parameter from URL for redirect after login
const nextUrl = Astro.url.searchParams.get('next') || undefined;
---

<Layout title="Zaloguj się - 10x Cards">
  <div class="min-h-screen bg-gradient-to-br from-background via-background to-muted/20 flex items-center justify-center px-4 py-12">
    <div class="w-full max-w-md space-y-8">
      <!-- Header -->
      <div class="text-center space-y-2">
        <a href="/" class="inline-block group">
          <h1 class="text-3xl font-bold tracking-tight group-hover:text-primary transition-colors">
            <span class="bg-gradient-to-r from-primary to-primary/60 bg-clip-text text-transparent">
              10x Cards
            </span>
          </h1>
        </a>
        <h2 class="text-2xl font-semibold">Zaloguj się</h2>
        <p class="text-muted-foreground">
          Wprowadź swoje dane, aby kontynuować
        </p>
      </div>

      <!-- Login Form Card -->
      <div class="rounded-lg border border-border bg-card shadow-lg p-8">
        <LoginForm nextUrl={nextUrl} client:load />
      </div>
    </div>
  </div>
</Layout>
