    "test:e2e:ai": "playwright test tests/e2e/ai-generation-with-cleanup.spec.ts tests/e2e/study-session-with-cleanup.spec.ts",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test": "npm run test:unit && npm run test:e2e:fast"
  },
  "dependencies": {
